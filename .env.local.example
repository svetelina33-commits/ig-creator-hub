# ======================================================================
# Nexus Club — environment configuration
# Copy this file to .env.local and fill in as you go.
# Everything except SESSION_SECRET and TOKEN_ENCRYPTION_KEY is optional
# for local dev; features gracefully degrade when not set.
# ======================================================================

# ---- Required for any Instagram OAuth flow ----
# developers.facebook.com → your app → Instagram product
IG_APP_ID=
IG_APP_SECRET=

# ---- Public base URL of this app ----
# Local dev: http://localhost:3000
# Production: https://<your-project>.vercel.app
APP_BASE_URL=http://localhost:3000

# ---- Required secrets (generate new per-env: `openssl rand -hex 32`) ----
SESSION_SECRET=replace-with-32-byte-hex
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-hex

# ---- OAuth scopes Instagram will show on the consent screen ----
IG_SCOPES=instagram_business_basic,instagram_business_manage_comments,instagram_business_content_publish

# ---- Admin gate (comma-separated emails) ----
# Any creator signed in with one of these emails can access /admin.
ADMIN_EMAILS=yashpanchalsx@gmail.com

# ---- Email (Resend). If blank, emails are logged to console instead. ----
# resend.com → API Keys → create. Free tier: 100 emails/day.
RESEND_API_KEY=
# Use a verified sender in prod. onboarding@resend.dev works without domain verification.
EMAIL_FROM=Nexus Club <onboarding@resend.dev>

# ---- Database (Neon Postgres). If blank, uses local JSON file store. ----
# neon.tech → new project → copy "Pooled connection" string.
# Run schema once: psql "$DATABASE_URL" -f src/lib/store-impl/schema.sql
DATABASE_URL=

# ---- Vercel Cron secret (prod only) ----
# Vercel dashboard will inject CRON_SECRET when you add the env var.
# If set, /api/cron/refresh-tokens requires Authorization: Bearer $CRON_SECRET.
CRON_SECRET=

# ---- Google OAuth (Gmail send) ----
# console.cloud.google.com → APIs & Services → Credentials → OAuth client ID (Web)
# Enable the "Gmail API" under Library first.
# Add these redirect URIs in the OAuth client:
#   http://localhost:3000/api/auth/google/callback
#   https://ig-creator-hub.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Default scopes: openid email profile + gmail.send. Adjust if you need broader access.
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.send
